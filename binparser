class TR31OptionalBlock(FieldSet):
    """One optional block: ID (2) + Len (2 hex) + Data.

    ``Len`` is two hex characters giving the *total* block length (in
    characters, i.e. bytes of ASCII), including the ID and length fields.
    A length field of ``00`` selects the extended form: the next two
    characters give the byte-count of a following hex length value.
    """

    def _peek(self, char_offset: int, count: int) -> str:
        bit_pos = self.absolute_address + self.current_size + char_offset * 8
        return self.stream.readBytes(bit_pos, count).decode("ascii", "replace")

    def createFields(self) -> GeneratorType:
        yield Enum(String(self, "id", 2, charset="ASCII"), TR31_OPT_BLOCK_ID)

        len_field = self._peek(0, 2)
        if len_field == "00":
            yield String(self, "length", 2, charset="ASCII")
            num = int(self._peek(0, 2), 16)
            yield ComputedBytes(
                self, "length_ext", 2, value=num, description="Extended length size"
            )
            total = int(self._peek(0, num), 16)
            yield String(self, "length_value", num, charset="ASCII")
            data_len = total - 4 - num
        else:
            total = int(len_field, 16)
            yield ComputedBytes(
                self, "length", 2, value=total, description="Block length"
            )
            data_len = total - 4

        if data_len > 0:
            yield String(self, "data", data_len, charset="ASCII")


class TR31Header(FieldSet):
    """TR-31 / X9.143 header (16 ASCII chars) followed by optional blocks."""

    endian = BIG_ENDIAN

    def createFields(self) -> GeneratorType:
        yield Enum(String(self, "version_id", 1, charset="ASCII"), TR31_VERSION_ID)
        yield String(self, "length", 4, charset="ASCII")
        yield Enum(String(self, "key_usage", 2, charset="ASCII"), TR31_KEY_USAGE)
        yield Enum(String(self, "algorithm", 1, charset="ASCII"), TR31_ALGORITHM)
        yield Enum(String(self, "mode_of_use", 1, charset="ASCII"), TR31_MODE_OF_USE)
        yield String(self, "key_version", 2, charset="ASCII")
        yield Enum(String(self, "exportability", 1, charset="ASCII"), TR31_EXPORTABILITY)
        yield String(self, "opt_blocks_count", 2, charset="ASCII")
        yield Enum(String(self, "key_context", 1, charset="ASCII"), TR31_KEY_CONTEXT)
        yield String(self, "reserved", 1, charset="ASCII")

        opt_count = int(self["opt_blocks_count"].value)
        for _ in range(opt_count):
            yield TR31OptionalBlock(self, "opt_block[]")


class TR31KeyBlock(FieldSet):
    """TR-31 / X9.143 key block — header + optional blocks, hex payload, authenticator."""

    endian = BIG_ENDIAN

    def createFields(self) -> GeneratorType:
        yield TR31Header(self, "header")

        version_id = self["header"]["version_id"].value
        total_len = int(self["header"]["length"].value)

        header_and_opts = self["header"].size // 8
        mac_bytes = _TR31_MAC_BYTES.get(version_id, 8)
        mac_chars = mac_bytes * 2
        payload_chars = total_len - header_and_opts - mac_chars

        if payload_chars > 0:
            yield String(self, "payload", payload_chars, charset="ASCII")
        if mac_chars > 0:
            yield String(self, "authenticator", mac_chars, charset="ASCII")


