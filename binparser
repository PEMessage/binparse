# ---------------------------------------------------------------------------
#  Hachoir-based C‑struct parsers
# ---------------------------------------------------------------------------
# To add a new parser, define a FieldSet + Parser subclass, then add the
# Parser to the PARSERS registry at the bottom of this block.  Everything
# else (extraction, colouring, info formatting, rendering) stays untouched.

class DemoA(FieldSet):
    """One 16-byte record."""

    def createFields(self) -> GeneratorType:
        yield UInt32(self, "id")
        yield UInt32(self, "timestamp")
        yield UInt16(self, "type")
        yield UInt16(self, "value")
        yield UInt8(self, "flag")
        yield RawBytes(self, "reserved", 3)


# --- Second parser: demonstrates nested containers (no repeated entries) ---


class DemoBHeader(FieldSet):
    def createFields(self) -> GeneratorType:
        yield UInt32(self, "magic")
        yield UInt16(self, "version")
        yield UInt16(self, "flags")


class DemoBBody(FieldSet):
    def createFields(self) -> GeneratorType:
        yield UInt32(self, "width")
        yield UInt32(self, "height")
        yield UInt16(self, "depth")


class DemoB(FieldSet):
    """Two named sections — flat hierarchy, no repetition."""

    endian = LITTLE_ENDIAN

    def createFields(self) -> GeneratorType:
        yield DemoBHeader(self, "header")
        yield DemoBBody(self, "info")


# --- Third parser: ASN.1 BER/DER (TLV with variable-length tag & length) ---


class ComputedBytes(RawBytes):
    """RawBytes that returns a pre-computed value of any type, instead of
    reading raw bytes from the stream.  This is the idiomatic hachoir
    pattern: subclass and override ``createValue()``.
    """

    def __init__(self, parent, name, length, value, description="Raw data"):
        super().__init__(parent, name, length, description)
        self._value = value

    def createValue(self):
        return self._value


class ASN1TLV(FieldSet):
    """One ASN.1 TLV record.

    Uses ``stream.readBytes`` to peek at the leading tag / length bytes
    so that a single consolidated ``RawBytes`` field is yielded for each
    logical component, regardless of how many bytes the encoding occupies.
    """

    def createFields(self) -> GeneratorType:
        # --- Tag (1 byte, possibly extended) ---
        bit_pos = self.absolute_address + self.current_size
        tag0 = self.stream.readBytes(bit_pos, 1)[0]

        if (tag0 & 0x1F) != 0x1F:
            tag_size = 1
        else:
            tag_size = 1
            while True:
                b = self.stream.readBytes(bit_pos + tag_size * 8, 1)[0]
                tag_size += 1
                if not (b & 0x80):
                    break
        yield RawBytes(self, "tag", tag_size)

        # --- Length (short-form 1 B, or long-form 1 + N B) ---
        bit_pos = self.absolute_address + self.current_size
        len0 = self.stream.readBytes(bit_pos, 1)[0]

        if not (len0 & 0x80):
            total, len_size = len0, 1
        else:
            num = len0 & 0x7F
            len_size = 1 + num
            total = 0
            for i in range(num):
                total = (total << 8) | self.stream.readBytes(
                    bit_pos + (1 + i) * 8, 1
                )[0]
        yield ComputedBytes(self, "length", len_size, value=total)

        # --- Value ---
        if total > 0:
            yield RawBytes(self, "value", total)


class ASN1TLVParser(Parser):
    """Stream of ASN.1 BER/DER TLV records — big-endian."""

    endian = BIG_ENDIAN

    def createFields(self) -> GeneratorType:
        while not self.eof:
            yield asn1.Object(self, "tlv[]")


