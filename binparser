def _parse_common_args() -> argparse.Namespace:
    ap = argparse.ArgumentParser(
        description="Binary struct parser — xxd-style output with ANSI colours"
    )
    _add_common_args(ap)
    sub = ap.add_subparsers(dest="cmd", required=True)

    sp_show = sub.add_parser("show", help="Render xxd-style hex dump with field info")
    sp_show.add_argument(
        "-c",
        "--color",
        choices=[m.value for m in ColorMode],
        default=ColorMode.ALL.value,
        help="Colouring: all (default), fg (foreground only), bg (background only), none",
    )
    sp_show.add_argument(
        "--show-xxd",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Print hex dump (default: true)",
    )
    sp_show.add_argument(
        "--show-xxd-idx",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Print index markers below hex dump (default: true)",
    )
    sp_show.add_argument(
        "--show-info",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Print field summary after the hex dump (default: true)",
    )
    sp_show.add_argument(
        "--show-info-idx",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Print field index numbers in field info (default: true)",
    )
    sp_show.add_argument(
        "--show-info-value",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Show extra value field in field info (default: true)",
    )
    sp_show.add_argument(
        "--show-info-abspath",
        action=argparse.BooleanOptionalAction,
        default=False,
        help="Print full absolute path for each field (default: false)",
    )
    sp_show.add_argument(
        "--show-trailing",
        action=argparse.BooleanOptionalAction,
        default=False,
        help="Include trailing raw/padding autofix fields (default: false)",
    )

    sp_dump = sub.add_parser("dump", help="Dump raw bytes of a field by index")
    sp_dump.add_argument(
        "index",
        type=int,
        help="Field index to dump",
    )
    sp_dump.add_argument(
        "--show-trailing",
        action=argparse.BooleanOptionalAction,
        default=False,
        help="Include trailing raw/padding autofix fields in indexing (default: false)",
    )

    return ap.parse_args()


def _add_common_args(ap: argparse.ArgumentParser) -> None:
    ap.add_argument(
        "-s",
        "--struct",
        choices=list(PARSERS) + list(FIELDS),
        required=True,
        help="Parser to use (%(choices)s)",
    )
    ap.add_argument(
        "-l",
        "--list",
        action=argparse.BooleanOptionalAction,
        default=False,
        help="List Parse",
    )
    ap.add_argument(
        "--offset",
        type=lambda v: int(v, 0),
        default=0,
        help="Skip this many bytes from the start of input (default: 0)",
    )
    ap.add_argument(
        "--limit",
        type=lambda v: int(v, 0),
        default=None,
        help="Process at most this many bytes (default: whole input)",
    )


def _load_data(args: argparse.Namespace) -> bytes:
    data = sys.stdin.buffer.read()
    if args.offset or args.limit is not None:
        start = args.offset
        end = start + args.limit if args.limit is not None else len(data)
        data = data[start:end]
    return data


def _create_parser(args: argparse.Namespace, field: Field) -> Parser:
    class WrapperParser(Parser):
        endian = LITTLE_ENDIAN
        def createFields(self) -> GeneratorType:
            if not args.list:
                yield field(self, "root")
            else:
                while not self.eof:
                    yield field(self, "root[]")

    return WrapperParser


def _parse_root(args: argparse.Namespace, data: bytes) -> Field:
    if args.struct in FIELDS:
        parser_cls = _create_parser(args, FIELDS[args.struct])
    else:
        parser_cls = PARSERS[args.struct]
    stream = StringInputStream(data)
    parser = parser_cls(stream)
    root = parser["/"]
    assert isinstance(root, Field)
    return root


def cmd_show(args: argparse.Namespace, data: bytes, root: Field) -> None:
    color_mode = ColorMode(args.color)


    unique_names = list(dict.fromkeys(_collect_leaf_names(root)))
    palette = RenderPalette(
        field_colors = auto_colors(names=unique_names) if color_mode.use_bg else {},
        char_fg = char_color if color_mode.use_fg else None,
    )

    if args.show_xxd:
        print(render_xxd(data, root, palette, args))
    if args.show_info:
        info = render_field_info(root, palette, args)
        if info:
            print(info)


def cmd_dump(args: argparse.Namespace, data: bytes, root: Field) -> None:
    for idx, field in _iter_indexed_fields(root, args.show_trailing):
        if idx == args.index:
            offset = field.absolute_address // 8
            size = field.size // 8
            sys.stdout.buffer.write(data[offset:offset + size])
            return
    print(f"error: index {args.index} not found", file=sys.stderr)
    sys.exit(1)


def main() -> None:
    args = _parse_common_args()
    data = _load_data(args)
    if not data:
        return
    root = _parse_root(args, data)

    if args.cmd == "show":
        cmd_show(args, data, root)
    elif args.cmd == "dump":
        cmd_dump(args, data, root)


if __name__ == "__main__":
    main()

